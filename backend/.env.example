# Copy this file to .env and fill in values.

# Option A: local PostgreSQL (default port)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/renewal_risk

# Option B: Docker PostgreSQL (port 5433 to avoid conflicts with a local install)
# DATABASE_URL=postgres://postgres:postgres@localhost:5433/renewal_risk

PORT=3000

# URL of the external Revenue Management System webhook endpoint.
# Use https://webhook.site for easy manual testing.
RMS_ENDPOINT=http://localhost:3001/webhook

# Shared secret used to sign webhook payloads (HMAC-SHA256).
# Change this to a long random string in any non-local environment.
WEBHOOK_SECRET=dev-secret-key-change-in-prod
